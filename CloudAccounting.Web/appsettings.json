{
        "Serilog": {
            "MinimumLevel": {
                "Default": "Information",
                "Override": {
                    "Microsoft.AspNetCore": "Warning",
                    "Microsoft.AspNetCore.Hosting": "Warning",
                    "Microsoft.AspNetCore.Routing.EndpointMiddleware": "Warning"
                }
            },           
            "Enrich": [
                "FromLogContext",
                "WithMachineName",
                "WithThreadId"
            ],
            "Properties": {
                "Application": "CloudAccounting"
              }
        },
        "LogConfig": {
            "HttpRequestLogging": true,
            "HttpRequestLogLevel": "Debug"
        },
    "AllowedHosts": "*",
    "Kestrel": {
        "EndpointDefaults": {
            "Protocols": "Http1"
        },
        "Endpoints": {
            "Https":{
                "Url": "https://[::]:7239"
            }
        }
    },    
  "ConnectionStrings": {
